{
  "manifest_version": 3,
  "name": "QuickDrop",
  "version": "1.0.0",
  "description": "A quick and easy browser extension that works on every website",
  "action": {
    "default_popup": "index.html",
    "default_title": "QuickDrop",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "identity",
    "notifications",
    "alarms",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
